# CarbonOps AI Studio - Environment Configuration
# Duplicate this file as .env and fill in your keys locally

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_TELEMETRY_ENDPOINT=wss://localhost:8000/ws/telemetry

# LLM / LangGraph Configuration (Backend passthrough)
VITE_LLM_PROVIDER=openai
VITE_OPENAI_MODEL=gpt-4-turbo

# Identity & Auth
VITE_AUTH_TENANT_ID=demo_hanover_ops
VITE_ROLE_OVERRIDE=Plant Manager
